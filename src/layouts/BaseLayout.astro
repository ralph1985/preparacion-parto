---
import "../styles/main.css";
import Header from "../components/ui/Header.astro";
import type { PageMeta, SiteSettings } from "../domain/site";

interface Props {
  site: SiteSettings;
  meta: PageMeta;
  currentPath?: string;
}

const { site, meta, currentPath = Astro.url.pathname } = Astro.props;
const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={meta.description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta property="og:title" content={meta.ogTitle} />
    <meta property="og:description" content={meta.ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={meta.ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.ogTitle} />
    <meta name="twitter:description" content={meta.ogDescription} />
    <title>{meta.title}</title>
    <link rel="canonical" href={currentPath} />
    <link
      rel="alternate"
      type="text/plain"
      title="Resumen para LLMs"
      href="/llms.txt"
    />
    <link
      rel="alternate"
      type="text/markdown"
      title="Curso completo en Markdown"
      href="/content/course-full.md"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/assets/img/favicons/favicon.svg?v=20260525174230"
    />
    <link
      rel="preload"
      href="/assets/fonts/manrope-500-700-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/playfair-display-700-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href="/assets/vendor/aos/aos.css?v=20260525174230" />
    {
      !isDev && (
        <link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
      )
    }
  </head>
  <body>
    <Header site={site} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="footer__container bd-container">
        <p>{site.footer}</p>
        <nav class="footer__nav" aria-label="Enlaces secundarios">
          <a href="/#recursos">Recursos</a>
          <a href="/content/course-full.md">Curso completo Markdown</a>
          <a href="/llms.txt">Resumen LLM</a>
          <a href="/#contacto">Contacto</a>
        </nav>
      </div>
    </footer>
    {
      !isDev && (
        <>
          <pagefind-modal id="pagefind-search" />
          <script
            is:inline
            type="module"
            src="/pagefind/pagefind-component-ui.js"
          />
        </>
      )
    }
    <script is:inline src="/assets/vendor/aos/aos.js?v=20260525174230"></script>
    <script>
      import "../scripts/site.js";
    </script>
  </body>
</html>
