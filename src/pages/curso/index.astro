---
import CourseLayout from "../../layouts/CourseLayout.astro";
import { getCourse } from "../../infrastructure/content/local-course-repository";
import { getSiteSettings } from "../../infrastructure/content/local-site-repository";

const site = await getSiteSettings();
const course = await getCourse();
const firstLesson = course.modules[0]?.lessons[0];
const totalLessons = course.modules.reduce(
  (count, module) => count + module.lessons.length,
  0,
);
const meta = {
  title: "Curso | Preparación al parto",
  description:
    "Curso privado de preparación al parto con lecciones sobre embarazo, parto, postparto, lactancia y cuidados del bebé.",
  ogTitle: "Curso | Preparación al parto",
  ogDescription:
    "Lecciones privadas de preparación al parto organizadas por módulos y cargadas desde Markdown.",
  ogImage:
    "/assets/img/generated/modulos-preparacion-parto.png?v=20260525174230",
};
---

<CourseLayout site={site} course={course} meta={meta}>
  <div class="course-index" data-pagefind-ignore>
    <p class="lesson__eyebrow">Empieza aquí</p>
    <h2>Curso multipágina</h2>
    <p>
      {course.modules.length} módulos y {totalLessons} lecciones con URLs estáticas
      para lectura, enlaces y acceso sin JavaScript. Puedes empezar por la primera
      lección o abrir cualquier tema directamente.
    </p>
    {
      firstLesson && (
        <p>
          <a class="button button--primary" href={`/curso/${firstLesson.id}/`}>
            Empezar: {firstLesson.title}
          </a>
        </p>
      )
    }
    <div class="course-index__grid">
      {
        course.modules.map((module, moduleIndex) => (
          <article class="course-index__module">
            <p class="course-index__eyebrow">Módulo {moduleIndex + 1}</p>
            <h3>{module.title}</h3>
            <p>
              {module.lessons.length}{" "}
              {module.lessons.length === 1 ? "lección" : "lecciones"}
            </p>
            <ul class="course-index__lessons">
              {module.lessons.map((lesson) => (
                <li>
                  <a href={`/curso/${lesson.id}/`}>{lesson.title}</a>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</CourseLayout>
