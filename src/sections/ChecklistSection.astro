<section class="checklist section" id="checklist">
  <div class="bd-container">
    <h2 class="section-title" data-aos="fade-up">Checklist</h2>
    <p class="section-subtitle" data-aos="fade-up">
      Tareas y recordatorios rápidos para revisar antes, durante y después del
      parto. El progreso se guarda solo en este navegador.
    </p>

    <div class="checklist__summary" data-aos="fade-up" aria-live="polite">
      <div>
        <p class="checklist__eyebrow">Progreso total</p>
        <p class="checklist__total" id="checklist-total">0 de 0</p>
      </div>
      <button
        class="button button--secondary checklist__reset-all"
        id="checklist-reset-all"
        type="button"
      >
        Reiniciar todo
      </button>
    </div>

    <div class="checklist__grid" id="checklist-grid" data-aos="fade-up"></div>
  </div>
</section>
