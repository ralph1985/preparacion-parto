{
  "name": "preparacion-parto",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "node scripts/build-course-full.mjs && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "lint": "pnpm run lint:astro && pnpm run lint:js && pnpm run format:check",
    "lint:astro": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint:js": "node --check src/scripts/site.js && node --check scripts/build-course-full.mjs",
    "format:check": "prettier --check package.json astro.config.mjs tsconfig.json prettier.config.mjs \"src/**/*.{astro,ts,js}\" \"scripts/**/*.mjs\""
  },
  "dependencies": {
    "astro": "7.0.4"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/node": "26.0.1",
    "prettier": "3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3"
  }
}
